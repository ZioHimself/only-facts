{
  "name": "only-facts",
  "version": "0.1.0",
  "description": "Campaign detection pipeline for coordinated inauthentic behavior",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cluster:baseline": "tsx src/scripts/run-tfidf-baseline.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "campaign-detection",
    "disinformation",
    "trust-safety"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "mongoose": "^8.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.3",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
