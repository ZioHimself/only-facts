{
  "name": "@only-facts/engine",
  "version": "0.1.0",
  "description": "Campaign detection pipeline - scraping, normalizing, and analyzing",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "cluster:baseline": "tsx src/scripts/run-tfidf-baseline.ts",
    "cluster:bot-analysis": "tsx src/scripts/run-bot-behavior-analysis.ts",
    "cluster:report-bot-vs-organic": "tsx src/scripts/report-bot-vs-organic.ts",
    "cluster:pipeline": "tsx src/scripts/run-cluster-pipeline.ts",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "campaign-detection",
    "disinformation",
    "trust-safety"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "mongoose": "^8.14.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "jest-util": "^29.7.0",
    "source-map-support": "^0.5.21",
    "js-yaml": "^4.1.1",
    "mongodb-memory-server": "^10.1.4",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
